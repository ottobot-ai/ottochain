[
  {
    "category": "Node Management",
    "endpoints": [
      {
        "endpoint": "/node/info",
        "method": "GET",
        "layer": "ALL",
        "description": "Get comprehensive node information including state, version, host, ports, peer ID, and session",
        "request_format": null,
        "response_format": "NodeInfo { state, session, clusterSession, version, host, publicPort, p2pPort, id }"
      },
      {
        "endpoint": "/node/state",
        "method": "GET",
        "layer": "ALL",
        "description": "Get current node state (Initial, ReadyToJoin, LoadingGenesis, GenesisReady, RollbackInProgress, RollbackDone, StartingSession, SessionStarted, WaitingForDownload, DownloadInProgress, Observing, WaitingForObserving, WaitingForReady, Ready, Leaving, Offline)",
        "request_format": null,
        "response_format": "NodeState (string enum)"
      },
      {
        "endpoint": "/node/health",
        "method": "GET",
        "layer": "ALL",
        "description": "Health check endpoint - returns 200 OK if node is healthy, 503 if unhealthy",
        "request_format": null,
        "response_format": "200 OK or 503 Service Unavailable"
      },
      {
        "endpoint": "/node/session",
        "method": "GET",
        "layer": "ALL",
        "description": "Get current session ID token",
        "request_format": null,
        "response_format": "{ session: string }"
      },
      {
        "endpoint": "/metrics",
        "method": "GET",
        "layer": "ALL",
        "description": "Prometheus metrics endpoint in OpenMetrics format",
        "request_format": null,
        "response_format": "text/plain (OpenMetrics 1.0.0)"
      },
      {
        "endpoint": "/metagraph/info",
        "method": "GET",
        "layer": "ML0, CL1, DL1",
        "description": "Get metagraph-specific node information including tessellation and metagraph versions",
        "request_format": null,
        "response_format": "MetagraphNodeInfo { state, session, clusterSession, externalIp, publicPort, p2pPort, selfId, tessellationVersion, metagraphVersion }"
      },
      {
        "endpoint": "/targets",
        "method": "GET",
        "layer": "ALL",
        "description": "Get Prometheus service discovery targets for all cluster peers",
        "request_format": null,
        "response_format": "[{ targets: [string], labels: { ip, peer_id, peer_id_short } }]"
      }
    ]
  },
  {
    "category": "Cluster Management",
    "endpoints": [
      {
        "endpoint": "/cluster/info",
        "method": "GET",
        "layer": "ALL",
        "description": "Get list of all peers in the cluster with their status",
        "request_format": null,
        "response_format": "[PeerInfo { id, ip, publicPort, p2pPort, session, state }]"
      },
      {
        "endpoint": "/cluster/session",
        "method": "GET",
        "layer": "ALL",
        "description": "Get current cluster session token",
        "request_format": null,
        "response_format": "{ token: string } or 404 if no session"
      },
      {
        "endpoint": "/cluster/peers",
        "method": "GET",
        "layer": "ALL (P2P)",
        "description": "Get detailed peer information (P2P endpoint)",
        "request_format": null,
        "response_format": "[ClusterPeer { id, ip, publicPort, p2pPort, session, state }]"
      },
      {
        "endpoint": "/cluster/discovery",
        "method": "GET",
        "layer": "ALL (P2P)",
        "description": "Get combined known and discovered peers for peer discovery protocol",
        "request_format": null,
        "response_format": "[ClusterPeer]"
      },
      {
        "endpoint": "/cluster/join",
        "method": "POST",
        "layer": "ALL (CLI)",
        "description": "Join the cluster by connecting to a known peer (CLI endpoint)",
        "request_format": "PeerToJoin { id, ip, p2pPort }",
        "response_format": "200 OK or error (Conflict for various join failures)"
      },
      {
        "endpoint": "/cluster/join",
        "method": "POST",
        "layer": "ALL (P2P Public)",
        "description": "Handle incoming join request from another peer",
        "request_format": "JoinRequest { id, ip, p2pPort, registrationRequest }",
        "response_format": "200 OK or Conflict with reason"
      },
      {
        "endpoint": "/cluster/leave",
        "method": "POST",
        "layer": "ALL (CLI)",
        "description": "Leave the cluster gracefully",
        "request_format": null,
        "response_format": "200 OK"
      },
      {
        "endpoint": "/registration/request",
        "method": "GET",
        "layer": "ALL (P2P Public)",
        "description": "Get registration request for peer handshake",
        "request_format": null,
        "response_format": "RegistrationRequest"
      },
      {
        "endpoint": "/registration/sign",
        "method": "POST",
        "layer": "ALL (P2P Public)",
        "description": "Sign a registration request during peer handshake",
        "request_format": "SignRequest",
        "response_format": "SignedRegistration"
      }
    ]
  },
