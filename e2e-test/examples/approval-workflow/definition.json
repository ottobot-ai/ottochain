{
  "states": {
    "draft": {
      "id": "draft",
      "isFinal": false,
      "metadata": null
    },
    "submitted": {
      "id": "submitted",
      "isFinal": false,
      "metadata": null
    },
    "approved": {
      "id": "approved",
      "isFinal": true,
      "metadata": null
    },
    "rejected": {
      "id": "rejected",
      "isFinal": true,
      "metadata": null
    }
  },
  "initialState": "draft",
  "transitions": [
    {
      "from": "draft",
      "to": "submitted",
      "eventName": "submit",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {
            "submittedAt": {
              "var": "event.timestamp"
            }
          }
        ]
      },
      "dependencies": []
    },
    {
      "from": "submitted",
      "to": "approved",
      "eventName": "approve",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {
            "approvedBy": {
              "var": "event.approver"
            }
          }
        ]
      },
      "dependencies": []
    },
    {
      "from": "submitted",
      "to": "rejected",
      "eventName": "reject",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {
            "rejectedBy": {
              "var": "event.approver"
            },
            "reason": {
              "var": "event.reason"
            }
          }
        ]
      },
      "dependencies": []
    }
  ],
  "metadata": {
    "name": "ApprovalWorkflow",
    "description": "A simple approval workflow state machine"
  }
}
