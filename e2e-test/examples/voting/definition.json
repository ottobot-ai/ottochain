{
  "states": {
    "pending": {
      "id": "pending",
      "isFinal": false,
      "metadata": null
    },
    "voting": {
      "id": "voting",
      "isFinal": false,
      "metadata": null
    },
    "completed": {
      "id": "completed",
      "isFinal": true,
      "metadata": null
    }
  },
  "initialState": "pending",
  "transitions": [
    {
      "from": "pending",
      "to": "voting",
      "eventName": "startVoting",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {
            "candidates": {
              "var": "event.candidates"
            }
          }
        ]
      },
      "dependencies": []
    },
    {
      "from": "voting",
      "to": "completed",
      "eventName": "endVoting",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "var": "state"
      },
      "dependencies": []
    }
  ],
  "metadata": {
    "name": "Voting",
    "description": "A simple voting state machine"
  }
}
