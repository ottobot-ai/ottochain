{
  "states": {
    "pending": {
      "id": "pending",
      "isFinal": false,
      "metadata": null
    },
    "confirmed": {
      "id": "confirmed",
      "isFinal": false,
      "metadata": null
    },
    "shipped": {
      "id": "shipped",
      "isFinal": false,
      "metadata": null
    },
    "delivered": {
      "id": "delivered",
      "isFinal": true,
      "metadata": null
    },
    "cancelled": {
      "id": "cancelled",
      "isFinal": true,
      "metadata": null
    }
  },
  "initialState": "pending",
  "transitions": [
    {
      "from": "pending",
      "to": "confirmed",
      "eventName": "confirm",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {
            "var": "event"
          }
        ]
      },
      "dependencies": []
    },
    {
      "from": "pending",
      "to": "cancelled",
      "eventName": "cancel",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {
            "cancelReason": {
              "var": "event.reason"
            }
          }
        ]
      },
      "dependencies": []
    },
    {
      "from": "confirmed",
      "to": "shipped",
      "eventName": "ship",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {
            "trackingNumber": {
              "var": "event.trackingNumber"
            }
          }
        ]
      },
      "dependencies": []
    },
    {
      "from": "shipped",
      "to": "delivered",
      "eventName": "deliver",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {
            "deliveredAt": {
              "var": "event.timestamp"
            }
          }
        ]
      },
      "dependencies": []
    }
  ],
  "metadata": {
    "name": "SimpleOrderStateMachine",
    "description": "A basic order fulfillment state machine"
  }
}
