{
  "states": {
    "pending": {
      "id": "pending",
      "isFinal": false,
      "metadata": null
    },
    "funded": {
      "id": "funded",
      "isFinal": false,
      "metadata": null
    },
    "released": {
      "id": "released",
      "isFinal": true,
      "metadata": null
    },
    "refunded": {
      "id": "refunded",
      "isFinal": true,
      "metadata": null
    }
  },
  "initialState": "pending",
  "transitions": [
    {
      "from": "pending",
      "to": "funded",
      "eventName": "fund",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {
            "depositor": {
              "var": "event.depositor"
            },
            "amount": {
              "var": "event.amount"
            }
          }
        ]
      },
      "dependencies": []
    },
    {
      "from": "funded",
      "to": "released",
      "eventName": "release",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {
            "beneficiary": {
              "var": "event.beneficiary"
            }
          }
        ]
      },
      "dependencies": []
    },
    {
      "from": "funded",
      "to": "refunded",
      "eventName": "refund",
      "guard": {
        "==": [
          1,
          1
        ]
      },
      "effect": {
        "merge": [
          {
            "var": "state"
          },
          {}
        ]
      },
      "dependencies": []
    }
  ],
  "metadata": {
    "name": "TokenEscrow",
    "description": "A simple token escrow state machine"
  }
}
